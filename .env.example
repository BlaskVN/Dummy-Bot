# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Database URL (SQLite)
DATABASE_URL=sqlite:data/bot.db?mode=rwc

# Log level filter
RUST_LOG=my_rust_bot=debug,serenity=info,poise=info

# Bot Owner ID (optional — auto-detected from Discord application info if not set)
OWNER_ID=your_discord_user_id_here
